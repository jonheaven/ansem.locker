# Server-side indexer — set in Vercel project env (not VITE_*)
# Required for /api/locks leaderboard and /api/wallet-locks
#
# QuickNode (recommended) — full HTTPS URL from dashboard:
# SOLANA_RPC_URL=https://YOUR-ENDPOINT.solana-mainnet.quiknode.pro/YOUR_TOKEN/
#
# Helius alternative:
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# HELIUS_API_KEY=YOUR_KEY

SOLANA_RPC_URL=
HELIUS_API_KEY=
